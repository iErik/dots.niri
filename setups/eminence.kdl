output "DP-2" {
  mode "2560x1080@60.0"
  scale 1.0
  position x=1920 y=0
  focus-at-startup
}

output "DP-3" {
  mode "2560x1080@60.0"
  position x=4480 y=-1080
  transform "270"
  scale 1.0
}

output "HDMI-A-1" {
  mode "1920x1080@60.0"
  position x=0 y=0
}

output "HDMI-A-2" {
  mode "4096x2160@30.0"
  position x=5560 y=0
}


